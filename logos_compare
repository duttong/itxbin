#!/usr/bin/env python3
"""Launcher for the LOGOS compare GUI."""

import os
import sys

# Suppress Mesa GLX warnings on hosts with limited X/GL.
os.environ.setdefault("QT_XCB_GL_INTEGRATION", "none")

HERE = os.path.dirname(os.path.abspath(__file__))
LOGOSDATA = os.path.join(HERE, "logosdata")
if LOGOSDATA not in sys.path:
    sys.path.insert(0, LOGOSDATA)

from logos_compare.logos_compare import main


if __name__ == "__main__":
    raise SystemExit(main())
